<?xml version="1.0" encoding="utf-8"?>
<!--
  Project Ember – app icon foreground
  Concept: ember glowing in an ash mound with rising smoke
  Transparent background, designed for use on dark surfaces.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer ash mound – wide dark ellipse -->
    <path
        android:pathData="M10,72 Q14,56 54,54 Q94,56 98,72 Q94,84 54,86 Q14,84 10,72Z"
        android:fillColor="#4A4A4A" />

    <!-- Mid ash layer – slightly lighter, slightly smaller -->
    <path
        android:pathData="M18,70 Q22,58 54,57 Q86,58 90,70 Q86,80 54,82 Q22,80 18,70Z"
        android:fillColor="#5E5E5E" />

    <!-- Inner ash ring surrounding ember -->
    <path
        android:pathData="M30,67 Q34,60 54,59 Q74,60 78,67 Q74,74 54,76 Q34,74 30,67Z"
        android:fillColor="#6B6B6B" />

    <!-- Ember glow – orange core -->
    <ellipse
        android:cx="54"
        android:cy="66"
        android:rx="14"
        android:ry="8"
        android:fillColor="#E85D04" />

    <!-- Ember hot centre – bright yellow-orange -->
    <ellipse
        android:cx="54"
        android:cy="65"
        android:rx="8"
        android:ry="5"
        android:fillColor="#FF8C42" />

    <!-- Ember brightest core -->
    <ellipse
        android:cx="54"
        android:cy="64"
        android:rx="3"
        android:ry="2"
        android:fillColor="#FFCC00" />

    <!-- Smoke wisp left -->
    <path
        android:pathData="M46,58 Q42,48 44,38 Q46,30 44,22"
        android:fillColor="#00000000"
        android:strokeColor="#808080"
        android:strokeWidth="2.5"
        android:strokeLineCap="round" />

    <!-- Smoke wisp centre -->
    <path
        android:pathData="M54,56 Q50,44 54,34 Q56,26 54,18"
        android:fillColor="#00000000"
        android:strokeColor="#909090"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Smoke wisp right -->
    <path
        android:pathData="M62,58 Q66,48 64,38 Q62,30 64,22"
        android:fillColor="#00000000"
        android:strokeColor="#808080"
        android:strokeWidth="2.5"
        android:strokeLineCap="round" />

    <!-- Small glowing ember sparks scattered on ash -->
    <ellipse
        android:cx="36"
        android:cy="70"
        android:rx="2"
        android:ry="1.2"
        android:fillColor="#E85D04" />
    <ellipse
        android:cx="72"
        android:cy="71"
        android:rx="1.8"
        android:ry="1.1"
        android:fillColor="#FF8C42" />
    <ellipse
        android:cx="44"
        android:cy="74"
        android:rx="1.5"
        android:ry="1"
        android:fillColor="#E85D04" />
    <ellipse
        android:cx="66"
        android:cy="74"
        android:rx="1.5"
        android:ry="1"
        android:fillColor="#FF8C42" />

</vector>
