<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>
    {% if view == 'tool' and tool %}{{ tool.name }}{% else %}Project Ember{% endif %}
  </title>
  <link rel="stylesheet" href="/static/ember.css?v=20260301_mount_scav_v4"/>
  <link rel="icon" href="/static/favicon.ico"/>
</head>
<body data-page="{{ 'chat' if view == 'chat' else 'tool' }}">
  <div class="layout">

    <!-- Sidebar -->
    <aside class="sidebar" aria-label="Sidebar navigation">
      <div class="sideHeader">
        <div class="sideTitle">Projects</div>
      </div>

      <nav class="sideNav">
        <details class="sideSection" open>
          <summary class="sideSectionHeader">Project Ember</summary>
          <div class="sideSectionBody">
            <a class="sideItem {{ 'active' if view == 'chat' else '' }}" href="/" title="Chat">Chat</a>
            <a class="sideItem disabled" href="#" title="Models (coming soon)">Models</a>
            <a class="sideItem disabled" href="#" title="Settings (coming soon)">Settings</a>
          </div>
        </details>

        {% for group, tools in tool_groups.items() %}
        <details class="sideSection" open>
          <summary class="sideSectionHeader">{{ group }}</summary>
          <div class="sideSectionBody">
            {% for t in tools %}
              <a class="sideItem {{ 'active' if (view == 'tool' and tool and tool.id == t.id) else '' }}"
                 href="/tools/{{ t.id }}"
                 title="{{ t.description or t.name }}">{{ t.name }}</a>
            {% endfor %}
          </div>
        </details>
        {% endfor %}
      </nav>

      <div class="sideFooter muted">local only</div>
    </aside>

    <!-- Main -->
    <main class="main">
      <header class="topbar">
        <div class="brand">
          <a class="logoBtn" href="https://darkrelay.net" target="_blank" rel="noreferrer" title="darkrelay.net">Ω</a>
          <div class="brandText">
            <div class="title">
              {% if view == 'tool' and tool %}{{ tool.name }}{% else %}Project Ember{% endif %}
            </div>
            <div class="subtitle">
              {% if view == 'tool' and tool %}{{ tool.description or 'tool' }}{% else %}local brain, less drama{% endif %}
            </div>
          </div>
        </div>

        <div class="topActions">
          {% if view == 'tool' and tool and tool.id == 'inventory' and tool.kind == 'iframe' %}
            <!-- IMPORTANT: these control the iframe, not the browser -->
            <button class="btn pill" id="invNavInventory" type="button" data-iframe-src="/inventory/">Inventory</button>
            <button class="btn pill" id="invNavAdd" type="button" data-iframe-src="/inventory/add">Add Part</button>
            <button class="btn pill" id="invNavAdmin" type="button" data-iframe-src="/inventory/admin">Admin</button>
            <button class="btn pill" id="invPushBtn" type="button">Push to GitHub</button>
          {% endif %}

          <label class="modeLabel">
            <span>Mode</span>
            <select id="modeSel">
              <option value="quick">Quick</option>
              <option value="medium" selected>Medium</option>
              <option value="deep">Deep</option>
            </select>
          </label>
        </div>
      </header>

      {% if view == 'tool' and tool %}
        <section class="panel">
          {% if tool.kind == 'iframe' %}
            <div style="margin-top:0; height: calc(100vh - 140px); border: 0; border-radius: 18px; overflow:hidden;">
              <iframe class="invFrame" id="toolFrame" title="{{ tool.name }}" src="{{ tool.iframe_src }}"></iframe>
            </div>
            {% if tool.hint %}
              <div class="invHint muted">{{ tool.hint }}</div>
            {% endif %}
          {% else %}
            <div class="muted" style="padding:18px">
              Native tool shell for <b>{{ tool.name }}</b> isn’t implemented yet.
            </div>
          {% endif %}
        </section>
      {% else %}
        <section class="chatWrap" aria-label="Chat">
          <div class="chat" id="chat"></div>

          <form class="composer" id="composer" autocomplete="off">
            <textarea id="msg" placeholder="Type here… (Enter to send, Shift+Enter for newline)" rows="2"></textarea>
            <button class="btn send" type="submit">Send</button>
          </form>

          <div class="hint muted">Tip: keep prompts concrete.</div>
        </section>
      {% endif %}

      <!-- cheap modal for push output -->
      <div class="modal" id="pushModal" aria-hidden="true">
        <div class="modalCard">
          <div class="modalHead">
            <div class="modalTitle">Push to GitHub</div>
            <button class="btn pill" id="pushClose" type="button">Close</button>
          </div>
          <pre class="output" id="pushOutput"></pre>
        </div>
      </div>

    </main>
  </div>

  <script src="/static/ember.js?v=20260301_mount_scav_v4"></script>

  <!-- Tool iframe navigation (kept here to avoid touching ember.js) -->
  <script>
  (function () {
    const frame = document.getElementById("toolFrame");
    if (!frame) return;

    function setActive(btn) {
      ["invNavInventory","invNavAdd","invNavAdmin"].forEach(id => {
        const b = document.getElementById(id);
        if (b) b.classList.remove("active");
      });
      if (btn) btn.classList.add("active");
    }

    function hook(id) {
      const btn = document.getElementById(id);
      if (!btn) return null;
      btn.addEventListener("click", function () {
        const src = btn.getAttribute("data-iframe-src");
        if (!src) return;
        frame.setAttribute("src", src);
        setActive(btn);
      });
      return btn;
    }

    const bInv = hook("invNavInventory");
    hook("invNavAdd");
    hook("invNavAdmin");

    // default highlight
    setActive(bInv);
  })();
  </script>
</body>
</html>
